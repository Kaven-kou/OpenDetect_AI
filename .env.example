# ── LLM：DeepSeek（必填）────────────────────────────────────────
OPENDETECT_LLM_MODEL="deepseek-chat"
OPENDETECT_LLM_BASE_URL="https://api.deepseek.com"
OPENDETECT_LLM_API_KEY="your-deepseek-api-key"

# ── Embeddings：阿里云 DashScope（必填）────────────────────────
OPENDETECT_EMBED_MODEL="text-embedding-v4"
OPENDETECT_EMBED_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
OPENDETECT_EMBED_API_KEY="your-dashscope-api-key"

# ── 向量数据库路径（本地目录，无需 Key）────────────────────────
CHROMA_PERSIST_DIR="./data/chroma_db"

# ── 检索管线（Hybrid + Self-Query + Rerank，均有默认值，可不填）──
# 粗召回候选池大小（dense + BM25 融合后、rerank 之前）
OPENDETECT_RETRIEVAL_POOL="30"
# 是否启用自查询（LLM 抽取年份/作者/标题过滤条件）
OPENDETECT_SELF_QUERY="true"
# 重排后端：llm（默认，复用 DeepSeek，零额外依赖）| dashscope（gte-rerank）| none
OPENDETECT_RERANK_BACKEND="llm"
# dashscope 重排模型（仅 backend=dashscope 时用，复用上面的 DashScope Key）
OPENDETECT_RERANK_MODEL="gte-rerank-v2"
# 噪音闸门：rerank 相关性分低于该阈值的段落丢弃（跨领域脏数据）
OPENDETECT_RERANK_MIN_SCORE="0.3"

# ── Human-in-the-Loop（通用审批原语；当前接入 Web 入库确认）────
OPENDETECT_HITL="true"
# 审批有效期（秒）；超时恢复会按拒绝处理
OPENDETECT_APPROVAL_TTL_SECONDS="1800"

# PDF 上传/远程下载大小上限（MB）
OPENDETECT_MAX_PDF_MB="50"
# 单篇论文最大页数
OPENDETECT_MAX_PDF_PAGES="200"
# 远程 PDF HTTPS 域名白名单（逗号分隔，可按数据源扩展）
OPENDETECT_PDF_ALLOWED_HOSTS="arxiv.org,export.arxiv.org,openaccess.thecvf.com,aclanthology.org"

# Web 允许来源（逗号分隔；生产环境填写真实前端域名）
OPENDETECT_CORS_ORIGINS="http://localhost:8000,http://127.0.0.1:8000"

# ── Verifier（RAG 回答事实性校验，不足时降级提示）─────────────
OPENDETECT_VERIFY="true"

# ── ArXiv MCP Server（已内置默认值，免 Key，一般无需修改）──────
OPENDETECT_ARXIV_MCP_URL="https://mcp.api-inference.modelscope.net/f26e1fc45ee54a/mcp"

# ── LangSmith 追踪（可选，默认关闭；不用可保持 false 并留空 Key）
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_PROJECT="OpenDetect_AI"
LANGCHAIN_API_KEY=""
